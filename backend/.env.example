# Primary AI provider: "anthropic" or "openai" (default: anthropic)
AI_PRIMARY_PROVIDER=anthropic

# Fallback AI provider: "anthropic", "openai", or leave empty to disable fallback
AI_FALLBACK_PROVIDER=

ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# PostgreSQL connection string — required for deterministic DB scoring
# If blank, scoring falls back to LLM-only mode (still works, less precise)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_job_countdown
